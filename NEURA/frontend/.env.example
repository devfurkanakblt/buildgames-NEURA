# Avalanche RPC URL (Fuji Testnet)
NEXT_PUBLIC_AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# WalletConnect Project ID (get from: https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# NeuraCore Contract Address (update after deployment)
NEXT_PUBLIC_NEURA_CORE_ADDRESS=0x0000000000000000000000000000000000000000

# IPFS Gateway
NEXT_PUBLIC_IPFS_GATEWAY=https://w3s.link/ipfs/

# Environment
NEXT_PUBLIC_CHAIN_ID=43113
